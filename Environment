// Crosswalk Component
export const Crosswalk = ({ position, rotation = 0, length = 4 }: { position: [number, number, number]; rotation?: number; length?: number }) => (
  <group position={position} rotation={[0, rotation, 0]}>
    {Array.from({ length: 8 }).map((_, i) => (
      <mesh key={i} position={[0, 0.005, -length / 2 + i * (length / 8) + 0.25]} rotation={[-Math.PI / 2, 0, 0]}>
        <planeGeometry args={[2, length / 10]} />
        <meshBasicMaterial color="#ffffff" />
      </mesh>
    ))}
  </group>
);

// Road Segment Component
export const RoadSegment = ({ position, rotation = 0, length = 10, width = 6 }: { 
  position: [number, number, number]; 
  rotation?: number; 
  length?: number;
  width?: number;
}) => (
  <group position={position} rotation={[0, rotation, 0]}>
    {/* Road surface */}
    <mesh position={[0, 0.01, 0]} rotation={[-Math.PI / 2, 0, 0]} receiveShadow>
      <planeGeometry args={[width, length]} />
      <meshStandardMaterial color="#1e293b" roughness={0.9} />
    </mesh>
    {/* Center line */}
    <mesh position={[0, 0.02, 0]} rotation={[-Math.PI / 2, 0, 0]}>
      <planeGeometry args={[0.1, length * 0.9]} />
      <meshBasicMaterial color="#fbbf24" />
    </mesh>
    {/* Edge lines */}
    {[-width / 2 + 0.2, width / 2 - 0.2].map((x, i) => (
      <mesh key={i} position={[x, 0.02, 0]} rotation={[-Math.PI / 2, 0, 0]}>
        <planeGeometry args={[0.1, length]} />
        <meshBasicMaterial color="#ffffff" />
      </mesh>
    ))}
  </group>
);

