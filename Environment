import { useRef } from 'react';
import { useFrame } from '@react-three/fiber';
import * as THREE from 'three';
import { TrafficLight } from './types';

// Traffic Light Component
export const TrafficLightObject = ({ light, simTime }: { light: TrafficLight; simTime: number }) => {
  const getActiveLight = () => {
    const cycle = (simTime + light.rotation) % 10;
    if (cycle < 5) return 'green';
    if (cycle < 7) return 'yellow';
    return 'red';
  };

  const activeLight = getActiveLight();

  return (
    <group position={light.position} rotation={[0, light.rotation, 0]}>
      {/* Pole */}
      <mesh position={[0, 1.5, 0]} castShadow>
        <cylinderGeometry args={[0.05, 0.05, 3, 8]} />
        <meshStandardMaterial color="#374151" />
      </mesh>
      {/* Housing */}
      <mesh position={[0, 3.2, 0.15]} castShadow>
        <boxGeometry args={[0.3, 0.8, 0.2]} />
        <meshStandardMaterial color="#1f2937" />
      </mesh>
      {/* Red light */}
      <mesh position={[0, 3.45, 0.26]}>
        <sphereGeometry args={[0.08, 16, 16]} />
        <meshStandardMaterial 
          color="#ef4444" 
          emissive="#ef4444" 
          emissiveIntensity={activeLight === 'red' ? 1 : 0.1} 
        />
      </mesh>
      {/* Yellow light */}
      <mesh position={[0, 3.2, 0.26]}>
        <sphereGeometry args={[0.08, 16, 16]} />
        <meshStandardMaterial 
          color="#eab308" 
          emissive="#eab308" 
          emissiveIntensity={activeLight === 'yellow' ? 1 : 0.1} 
        />
      </mesh>
      {/* Green light */}
      <mesh position={[0, 2.95, 0.26]}>
        <sphereGeometry args={[0.08, 16, 16]} />
        <meshStandardMaterial 
          color="#22c55e" 
          emissive="#22c55e" 
          emissiveIntensity={activeLight === 'green' ? 1 : 0.1} 
        />
      </mesh>
    </group>
  );
};

